<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Welcome Portal - Home Page</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f4f6f7;
            text-align: center;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        ul.nav-menu {
            list-style-type: none;
            padding: 0;
            margin: 20px 0;
            background-color: #2c3e50;
            border-radius: 4px;
            overflow: hidden;
        }
        ul.nav-menu li {
            display: inline-block;
        }
        ul.nav-menu li a {
            display: block;
            color: white;
            padding: 14px 20px;
            text-decoration: none;
            font-weight: bold;
        }
        ul.nav-menu li a:hover {
            background-color: #3498db;
        }
                iframe {
            width: 100%;
            height: 450px;
            border: 2px solid #bdc3c7;
            border-radius: 4px;
            margin-top: 15px;
        }
        .banner-img {
            max-width: 100%;
            height: 150px;
            object-fit: cover;
            border-radius: 4px;
        }
    </style>
</head>
<body>
<div class="container">
    <img src="https://picsum.photos/900/200" alt="Portal Banner Image" class="banner-img">
    <h1>Welcome to the Member Portal</h1>
    <p>Please select an option below to access your account dashboard.</p>
    <ul class="nav-menu">
        <li><a href="login.html" target="content-frame">User Login</a></li>
        <li><a href="register.html" target="content-frame">Create an Account</a></li>
    </ul>
    <iframe src="login.html" name="content-frame" title="Sub-page Workspace"></iframe>
</div>
</body>
</html>

